# 金蝶云星空 API 连接配置
KD_SERVER_URL=http://your-kingdee-server:port
KD_DBID=your-db-id
KD_APP_KEY=your-app-key
KD_APP_SECRET=your-app-secret
KD_USERNAME=your-integration-username
KD_PASSWORD=your-integration-password

# 数据起始日期（只拉取此日期之后的单据）
DATA_START_DATE=2026-01-01

# 服务端口
PORT=4000

# 缓存过期时间（秒，默认 300 = 5 分钟）
CACHE_TTL=300
